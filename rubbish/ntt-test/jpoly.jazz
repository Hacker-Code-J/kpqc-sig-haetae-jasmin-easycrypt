export
fn poly_ntt_jazz(reg mut ptr u16[MLKEM_N] rp) -> reg ptr u16[MLKEM_N]
{
  rp = _poly_ntt(rp);
  return rp;
}

export
fn poly_invntt_jazz(reg mut ptr u16[MLKEM_N] rp) -> reg ptr u16[MLKEM_N]
{
  rp = _poly_invntt(rp);
  return rp;
}

export
fn poly_basemul_jazz(reg mut ptr u16[MLKEM_N] rp,
                     reg const ptr u16[MLKEM_N] ap bp) -> reg ptr u16[MLKEM_N]
{
  rp = _poly_basemul(rp, ap, bp);
  return rp;
}